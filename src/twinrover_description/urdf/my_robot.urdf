<?xml version="1.0"?>
<robot name="my_robot">

  <!-- ================= BASE ================= -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.0635"/>
      <geometry>
        <box size="0.305 0.305 0.254"/>
      </geometry>
      <material name="gray">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.0635"/>
      <geometry>
        <box size="0.305 0.305 0.254"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="6.8"/>
      <inertia
        ixx="0.089" ixy="0.0" ixz="0.0"
        iyy="0.089" iyz="0.0"
        izz="0.105"/>
    </inertial>
  </link>

  <!-- ================= LEFT WHEEL ================= -->
  <link name="front_left_wheel">
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.032"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.032"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.194"/>
      <inertia
        ixx="0.00019" ixy="0.0" ixz="0.0"
        iyy="0.00019" iyz="0.0"
        izz="0.00035"/>
    </inertial>
  </link>

  <joint name="front_left_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0 0.200 -0.06"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ================= RIGHT WHEEL ================= -->
  <link name="front_right_wheel">
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.032"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.032"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.194"/>
      <inertia
        ixx="0.00019" ixy="0.0" ixz="0.0"
        iyy="0.00019" iyz="0.0"
        izz="0.00035"/>
    </inertial>
  </link>

  <joint name="front_right_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0 -0.200 -0.06"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ================= REAR CASTER ================= -->
  <link name="rear_caster">
    <visual>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="gray">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia
        ixx="0.0002" ixy="0.0" ixz="0.0"
        iyy="0.0002" iyz="0.0"
        izz="0.0002"/>
    </inertial>
  </link>

  <joint name="rear_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_caster"/>
    <origin xyz="-0.12 0 -0.09"/>
  </joint>

  <!-- ================= FRONT CASTER ================= -->
  <link name="front_caster">
    <visual>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="gray">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia
        ixx="0.0002" ixy="0.0" ixz="0.0"
        iyy="0.0002" iyz="0.0"
        izz="0.0002"/>
    </inertial>
  </link>

  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_caster"/>
    <origin xyz="0.12 0 -0.09"/>
  </joint>

  <!-- ================= LIDAR (SICK TiM561) ================= -->
  <!-- Mounted front-top of chassis, z=0.22 from base_link origin -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <!-- TiM561 approx dimensions: 60mm wide x 86mm tall -->
        <box size="0.086 0.060 0.086"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.2 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.086 0.060 0.086"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.25"/>
      <inertia
        ixx="0.0001" ixy="0.0" ixz="0.0"
        iyy="0.0001" iyz="0.0"
        izz="0.00005"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <!-- Centered, top of chassis -->
    <origin xyz="0 0 0.22" rpy="0 0 0"/>
  </joint>

  <!-- ================= CAMERA (USB Webcam) ================= -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.03 0.08 0.03"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.03 0.08 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia
        ixx="0.0001" ixy="0.0" ixz="0.0"
        iyy="0.0001" iyz="0.0"
        izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <!-- Above LiDAR, forward-facing -->
    <origin xyz="0 0 0.27" rpy="0 0 0"/>
  </joint>

  <!-- camera_optical_frame: ROS convention (Z forward, X right, Y down) -->
  <link name="camera_optical_frame"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- ================= IMU (MPU-6050) ================= -->
  <!-- Centered in robot body for best Nav2 performance -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.005"/>
      </geometry>
      <material name="green">
        <color rgba="0.1 0.8 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.02 0.02 0.005"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <inertia
        ixx="0.000001" ixy="0.0" ixz="0.0"
        iyy="0.000001" iyz="0.0"
        izz="0.000001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <!-- Centered horizontally, mid-height of chassis -->
    <origin xyz="0 0 0.0635" rpy="0 0 0"/>
  </joint>

</robot>
