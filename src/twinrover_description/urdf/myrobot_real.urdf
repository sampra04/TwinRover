<?xml version="1.0"?>
<robot name="my_robot">

  <!-- ================= BASE ================= -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.0635"/>
      <geometry>
        <box size="0.305 0.305 0.254"/>
      </geometry>
      <material name="gray">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.0635"/>
      <geometry>
        <box size="0.305 0.305 0.254"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="6.8"/>
      <inertia
        ixx="0.089" ixy="0.0" ixz="0.0"
        iyy="0.089" iyz="0.0"
        izz="0.105"/>
    </inertial>
  </link>

  <!-- ================= LIDAR (SICK TiM561) ================= -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.086 0.060 0.086"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.2 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.086 0.060 0.086"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.25"/>
      <inertia
        ixx="0.0001" ixy="0.0" ixz="0.0"
        iyy="0.0001" iyz="0.0"
        izz="0.00005"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.22" rpy="0 0 0"/>
  </joint>

  <!-- ================= CAMERA (USB Webcam) ================= -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.03 0.08 0.03"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.03 0.08 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia
        ixx="0.0001" ixy="0.0" ixz="0.0"
        iyy="0.0001" iyz="0.0"
        izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0 0 0.27" rpy="0 0 0"/>
  </joint>

  <!-- camera_optical_frame: ROS convention (Z forward, X right, Y down) -->
  <link name="camera_optical_frame"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- ================= IMU (MPU-6050) ================= -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.005"/>
      </geometry>
      <material name="green">
        <color rgba="0.1 0.8 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.02 0.02 0.005"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <inertia
        ixx="0.000001" ixy="0.0" ixz="0.0"
        iyy="0.000001" iyz="0.0"
        izz="0.000001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.0635" rpy="0 0 0"/>
  </joint>
  
<!-- ================= WHEELS ================= -->
<link name="front_left_wheel">
  <visual>
    <geometry>
      <cylinder radius="0.060" length="0.04"/>
    </geometry>
    <material name="black">
      <color rgba="0.1 0.1 0.1 1.0"/>
    </material>
  </visual>
  <collision>
    <geometry>
      <cylinder radius="0.060" length="0.04"/>
    </geometry>
  </collision>
  <inertial>
    <mass value="0.5"/>
    <inertia
      ixx="0.0005" ixy="0.0" ixz="0.0"
      iyy="0.0005" iyz="0.0"
      izz="0.0009"/>
  </inertial>
</link>

<joint name="front_left_wheel" type="continuous">
  <parent link="base_link"/>
  <child link="front_left_wheel"/>
  <origin xyz="0 0.20 0" rpy="-1.5708 0 0"/>
  <axis xyz="0 0 1"/>
</joint>

<link name="front_right_wheel">
  <visual>
    <geometry>
      <cylinder radius="0.060" length="0.04"/>
    </geometry>
    <material name="black">
      <color rgba="0.1 0.1 0.1 1.0"/>
    </material>
  </visual>
  <collision>
    <geometry>
      <cylinder radius="0.060" length="0.04"/>
    </geometry>
  </collision>
  <inertial>
    <mass value="0.5"/>
    <inertia
      ixx="0.0005" ixy="0.0" ixz="0.0"
      iyy="0.0005" iyz="0.0"
      izz="0.0009"/>
  </inertial>
</link>

<joint name="front_right_wheel" type="continuous">
  <parent link="base_link"/>
  <child link="front_right_wheel"/>
  <origin xyz="0 -0.20 0" rpy="-1.5708 0 0"/>
  <axis xyz="0 0 1"/>
</joint>
<ros2_control name="RoboClawSystem" type="system">
  <hardware>
    <plugin>roboclaw_hardware_interface/RoboClawHardwareInterface</plugin>
    <param name="serial_port">/dev/ttyACM0</param>
  </hardware>
  <joint name="front_left_wheel">
    <command_interface name="velocity"/>
    <state_interface name="position"/>
    <param name="address">128</param>
    <param name="qppr">754</param>
    <param name="motor_type">M2</param>
    <param name="max_current">4.5</param>
  </joint>
  <joint name="front_right_wheel">
    <command_interface name="velocity"/>
    <state_interface name="position"/>
    <param name="address">128</param>
    <param name="qppr">754</param>
    <param name="motor_type">M1</param>
    <param name="max_current">4.5</param>
  </joint>
</ros2_control>

</robot>

